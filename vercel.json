{
  "rewrites": [
    { "source": "/login", "destination": "/login-page/login.html" },
    { "source": "/signup", "destination": "/login-page/signup.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/profile", "destination": "/setting.html" },
    { "source": "/settings", "destination": "/setting.html" },
    { "source": "/course-content", "destination": "/course-content.html" },
    { "source": "/create-course", "destination": "/create-course.html" },
    { "source": "/manage-courses", "destination": "/manage-courses.html" },
    { "source": "/check-model", "destination": "/check_model.html" }
  ],
  "headers": [
    {
      "source": "/course-content.html",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    },
    {
      "source": "/course-content",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    }
  ]
}